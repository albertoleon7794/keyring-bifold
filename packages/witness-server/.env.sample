# =============================================================================
# Witness Server Configuration
# Copy to .env and customize for your deployment
# =============================================================================

# --- Server ---
WITNESS_NAME=witness-server
WITNESS_PORT=9002                          # DIDComm HTTP transport
WITNESS_WEB_PORT=9003                      # QR code invitation page

# ⚠️  IMPORTANT: DO NOT USE 'localhost' IF TESTING WITH MOBILE DEVICES ⚠️
# 'localhost' only works for same-machine testing. Mobile devices cannot reach 'localhost'.
#
# For mobile app testing, use your server machine's LAN IP address:
#   Linux:  ip addr show | grep "inet 192"
#   Linux:  hostname -I | awk '{print $1}'
#   macOS:  ipconfig getifaddr en0
#
# Example: WITNESS_PUBLIC_URL=http://192.168.1.100:9002
#
# For same-machine testing only:
# WITNESS_PUBLIC_URL=http://localhost:9002
#
# For mobile/multi-device testing (RECOMMENDED):
WITNESS_PUBLIC_URL=http://YOUR_LAN_IP:9002   # Replace YOUR_LAN_IP with your actual IP (e.g., 192.168.1.100)

# --- TLS/HTTPS Configuration ---
# HTTPS is DISABLED BY DEFAULT.
# TLS is optional and only needed if you want to access the web UI over HTTPS.
#
# To enable HTTPS (optional - for web UI only):
# WITNESS_TLS_ENABLED=true                 # Enable HTTPS (default: false)
# WITNESS_TLS_CERT=/path/to/cert.pem       # Custom certificate path (optional)
# WITNESS_TLS_KEY=/path/to/key.pem         # Custom key path (optional)
# WITNESS_TLS_CERTS_DIR=.certs             # Directory for auto-generated certs (default: .certs)
# WITNESS_TLS_AUTO_GENERATE=true           # Auto-generate cert if not found (default: true)
# WITNESS_TLS_VALIDITY_DAYS=365            # Certificate validity in days (default: 365)
# WITNESS_TLS_HOSTNAMES=localhost,192.168.1.100  # Comma-separated hostnames/IPs for cert SAN

# --- Session ---
WITNESS_SESSION_EXPIRATION=30              # Minutes before session expires

# --- Invitation Persistence ---
# Persists invitation URL to file for stable QR codes across restarts
WITNESS_INVITATION_FILE=.oob-invitation.json  # Set to "" to disable persistence

# --- Mediator (optional) ---
# If set, connects through a DIDComm mediator using WebSocket instead of direct HTTP.
# This eliminates the need for a publicly accessible port.
# MEDIATOR_INVITATION_URL=https://mediator.example.com/invite?oob=eyJ...

# Timeout in milliseconds to wait for mediator connection (default: 10000 = 10 seconds)
# WITNESS_MEDIATOR_CONNECTION_TIMEOUT=10000

# --- Event (included in VWC witnessContext) ---
# WITNESS_EVENT_NAME=EthDenver 2024
WITNESS_VERIFICATION_METHOD=session-based-challenge

# --- Event Time Window (optional) ---
# Witnessing requests outside this window are rejected with a clear error message.
# Both variables are optional. Omit either (or both) to disable that gate.
# Format: ISO 8601 with timezone offset (recommended for clarity)
#
# Examples:
#   WITNESS_EVENT_START=2026-04-01T09:00:00-07:00   # PDT
#   WITNESS_EVENT_START=2026-04-01T16:00:00Z         # UTC
#
# If set, participants who request a session before WITNESS_EVENT_START receive:
#   { "type": "error", "code": "event-not-started", "message": "...", "eventStartTime": "..." }
#
# If set, participants who request a session after WITNESS_EVENT_END receive:
#   { "type": "error", "code": "event-ended", "message": "...", "eventEndTime": "..." }
#
# WITNESS_EVENT_START=2026-04-01T09:00:00-07:00
# WITNESS_EVENT_END=2026-04-01T17:00:00-07:00

# --- DID Configuration ---
# Priority: ISSUER_DID > ISSUER_KEY_FILE > ISSUER_SEED > auto-generate
#
# Option 1: Stable did:peer from seed (recommended for production)
# WITNESS_ISSUER_SEED=<64-hex-chars>        # 32 bytes = 64 hex characters
#
# Option 2: Import existing DID with seed
# WITNESS_ISSUER_DID=did:key:z6Mk...
# WITNESS_ISSUER_SEED=<64-hex-chars>
#
# Option 3: Import existing DID with key file
# WITNESS_ISSUER_DID=did:web:witness.example.com
# WITNESS_ISSUER_KEY_FILE=/run/secrets/witness-key.json
#
# Key file format: { "seed": "hex", "privateKeyHex": "hex", "privateKeyBase64": "base64" }

# --- Opt-in Activity Reporting ---
# When enabled, the witness accepts per-user reporting DIDs and records
# a graph edge when BOTH parties in an exchange opt in.
# Individual users can still toggle reporting off in the app.
# WITNESS_REPORTING_ENABLED=true           # Uncomment to disable at server level (enabled by default)
# WITNESS_REPORTING_DIR=.reporting         # Directory for reporting graph data (default: .reporting)

# --- Co-Locality Verification ---
# Cryptographic challenge/proof that participants are co-located with the witness.
# ENABLED BY DEFAULT. Evidence is included in VWC witnessContext.
#
# Transport: TODO - Bluetooth BLE (mDNS removed — was unreliable).
# Participants prove co-location by obtaining the current challenge (via BLE once
# implemented) and POSTing it with their DID and signature to /oracle/verify-locality.

# WITNESS_LOCALITY_ENABLED=false           # Uncomment and set to 'false' to disable (enabled by default)
# WITNESS_LOCALITY_REQUIRED=false          # Set to 'false' to make verification optional (required by default)
#                                          # When required=false, sessions can proceed without locality proofs,
#                                          # but proofs will still be included in VWCs if available
WITNESS_LOCALITY_PROOF_LIFETIME_MINUTES=30       # How long locality proofs remain valid
WITNESS_LOCALITY_CHALLENGE_ROTATION_MINUTES=5    # How often the challenge rotates
WITNESS_LOCALITY_IP_MASKING=masked               # IP in VWC: 'full', 'masked', 'hash', 'none'

# --- LLM / AI Assistant ---
# Enable AI-powered responses to user messages via LangChain.js + Claude
# DISABLED BY DEFAULT. Requires Anthropic API key when enabled.
#
# WITNESS_LLM_ENABLED=true                                      # Enable LLM features (default: false)
# WITNESS_ANTHROPIC_API_KEY=sk-ant-...                          # Required when LLM_ENABLED=true
# WITNESS_ANTHROPIC_BASE_URL=https://your-proxy.example.com     # Optional: Custom API base URL (e.g., for proxy)
# WITNESS_ANTHROPIC_MODEL=claude-sonnet-4-20250514              # Optional: Model to use (default: claude-sonnet-4-20250514)
# WITNESS_ANTHROPIC_MAX_TOKENS=500                              # Optional: Max tokens per response (default: 500)
# WITNESS_ANTHROPIC_TEMPERATURE=0.7                             # Optional: Temperature 0-1 (some models don't support this)
# WITNESS_CONTEXT_ORGANIZATION=./examples/organization-context.md
# WITNESS_CONTEXT_EVENT=./examples/event-context.md
# WITNESS_CONTEXT_CAPABILITIES=./examples/app-capabilities.md
#
# Rate limiting (prevents API abuse):
# WITNESS_LLM_RATE_LIMIT_PER_USER=10                            # Max requests per user per time window (default: 10)
# WITNESS_LLM_RATE_LIMIT_USER_WINDOW=60                         # User rate limit window in seconds (default: 60)
# WITNESS_LLM_RATE_LIMIT_GLOBAL=100                             # Max requests globally per time window (default: 100)
# WITNESS_LLM_RATE_LIMIT_GLOBAL_WINDOW=60                       # Global rate limit window in seconds (default: 60)

# --- Debug ---
WITNESS_VERBOSE=false

# --- Message Retention ---
# Whether to retain basic message records in the witness wallet after processing.
# When false (default), messages are deleted after processing to preserve user privacy.
# When true, all messages are retained for debugging/audit purposes.
# Note: This only affects the witness's storage - users' devices retain their own message history.
# WITNESS_RETAIN_MESSAGES=true     # Uncomment to enable message retention (disabled by default)

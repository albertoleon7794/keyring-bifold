{
  "name": "@bifold/witness-server",
  "version": "1.0.0",
  "private": true,
  "description": "Witness server for VRC witnessed exchanges over DIDComm",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:runtime": "esbuild src/network-ui/runtime/index.ts --bundle --outfile=dist/network-runtime.js --format=iife --platform=browser --sourcemap --loader:.js=js",
    "build:runtime:prod": "esbuild src/network-ui/runtime/index.ts --bundle --outfile=dist/network-runtime.js --format=iife --platform=browser --minify --loader:.js=js",
    "build:all": "yarn build && yarn build:runtime",
    "start": "yarn build:runtime && ts-node src/index.ts",
    "start:prod": "node dist/index.js",
    "start:fresh": "yarn fresh && yarn start",
    "dev": "ts-node-dev --respawn src/index.ts",
    "dev:runtime": "esbuild src/network-ui/runtime/index.ts --bundle --outfile=dist/network-runtime.js --format=iife --platform=browser --sourcemap --watch --loader:.js=js",
    "network:synthetic": "yarn build:runtime && ts-node src/network-synthetic.ts",
    "network:reporting": "yarn build:runtime && ts-node src/network-reporting.ts",
    "network:synthetic:dev": "yarn build:runtime && ts-node-dev --respawn src/network-synthetic.ts",
    "network:reporting:dev": "yarn build:runtime && ts-node-dev --respawn src/network-reporting.ts",
    "fresh": "ts-node src/cleanWallet.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "docker:clear-reporting": "docker compose -f docker-compose.yml down -v"
  },
  "dependencies": {
    "@bifold/vrc-contexts": "workspace:*",
    "@bifold/vrc-shared": "workspace:*",
    "@credo-ts/askar": "0.5.17",
    "@credo-ts/core": "0.5.17",
    "@credo-ts/node": "0.5.17",
    "@hyperledger/aries-askar-nodejs": "^0.2.3",
    "@langchain/anthropic": "^1.3.25",
    "@langchain/core": "^1.1.36",
    "dotenv": "^17.2.3",
    "langchain": "^0.3.6",
    "qrcode": "^1.5.3",
    "selfsigned": "^5.5.0",
    "three": "^0.183.2",
    "unique-names-generator": "^4.7.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/selfsigned": "^2.0.4",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.24.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.4.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "~5.5.2"
  }
}
